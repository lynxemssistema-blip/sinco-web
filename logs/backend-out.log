tar,'') AS DECIMAL(10,2))), 0) AS TotalDobra, COALESCE(SUM(CAST(NULLIF(t.DobraTotalExecutado,'') AS DECIMAL(10,2))), 0) AS ExecDobra, /* Ã¢â€â‚¬Ã¢â€â‚¬ Setor Solda Ã¢â€â‚¬Ã¢â€â‚¬ */ COALESCE(SUM(CAST(NULLIF(t.SoldaTotalExecutar,'') AS DECIMAL(10,2))), 0) AS TotalSolda, COALESCE(SUM(CAST(NULLIF(t.SoldaTotalExecutado,'') AS DECIMAL(10,2))), 0) AS ExecSolda, /* Ã¢â€â‚¬Ã¢â€â‚¬ Setor Pintura Ã¢â€â‚¬Ã¢â€â‚¬ */ COALESCE(SUM(CAST(NULLIF(t.PinturaTotalExecutar,'') AS DECIMAL(10,2))), 0) AS TotalPintura, COALESCE(SUM(CAST(NULLIF(t.PinturaTotalExecutado,'') AS DECIMAL(10,2))), 0) AS ExecPintura, /* Ã¢â€â‚¬Ã¢â€â‚¬ Setor Montagem Ã¢â€â‚¬Ã¢â€â‚¬ */ COALESCE(SUM(CAST(NULLIF(t.MontagemTotalExecutar,'') AS DECIMAL(10,2))), 0) AS TotalMontagem, COALESCE(SUM(CAST(NULLIF(t.MontagemTotalExecutado,'') AS DECIMAL(10,2))), 0) AS ExecMontagem FROM projetos p LEFT JOIN tags t ON t.IdProjeto = p.IdProjeto AND (t.D_E_L_E_T_E IS NULL OR t.D_E_L_E_T_E = '') WHERE COALESCE(p.D_E_L_E_T_E,'') = '' AND COALESCE(p.liberado,'') != '' GROUP BY p.IdProjeto ORDER BY p.IdProjeto DESC LIMIT 300
